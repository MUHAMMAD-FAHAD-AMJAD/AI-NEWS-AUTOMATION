# baileys-sender environment variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
#
# These are only needed for LOCAL runs of first-time-setup.js.
# In GitHub Actions, all secrets are injected automatically.
# ─────────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here
WHATSAPP_CHANNEL_JID=120363XXXXXXXXXX@newsletter
